# Turath Chain Root .env.example

# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/turath_db

# Redis
REDIS_URL=redis://localhost:6379

# NextAuth
AUTH_SECRET=replace-with-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# External APIs
USUL_ASSETS_URL=https://assets.usul.ai

# Optional local OpenITI corpus checkout for YML relation import
OPENITI_DATA_DIR=

# Qdrant (Fase 2 semantic search)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=turath_chunks
QDRANT_API_KEY=replace-with-qdrant-api-key

# Embedding model (Fase 2)
EMBEDDING_PROVIDER=vertex
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768

# Vertex AI embedding provider
GOOGLE_CLOUD_PROJECT=replace-with-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true

# Local embedding provider
LOCAL_EMBEDDING_URL=http://localhost:8000

# Passim data (Fase 3)
PASSIM_DATA_PATH=./data/passim
PASSIM_MIN_SIMILARITY=0.7
