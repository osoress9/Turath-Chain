{
  "name": "turath-chain-api",
  "version": "1.0.0",
  "description": "Backend API for Turath Chain using Hono.js",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:index-content": "tsx prisma/index-content.ts",
    "index:content": "tsx prisma/index-content.ts",
    "db:import-openiti-relations": "tsx prisma/import-openiti-relations.ts"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.8.0",
    "@prisma/client": "^6.2.0",
    "@qdrant/qdrant-js": "^1.18.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prisma": "^6.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
